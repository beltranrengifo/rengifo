---
import SectionHeader from './SectionHeader.astro';
import { t, resolveLocale } from '../lib/i18n';
import { capabilities } from '../data/capabilities';

const locale = resolveLocale(Astro.currentLocale);
---

<section class="mx-auto max-w-[1080px] px-6 pb-10 sm:px-10">
  <SectionHeader number="03" titleKey="ui_section_capabilities" class="mb-12" />

  <p
    data-reveal
    class="text-body mt-[-24px] mb-12 max-w-[620px] font-serif text-[19px] italic"
  >
    {t('ui_capabilities_intro', locale)}
  </p>

  <div
    data-reveal
    class="grid grid-cols-[repeat(auto-fit,minmax(210px,1fr))] gap-12 pb-16"
  >
    {
      capabilities.map((col) => (
        <div>
          <h3 class="text-muted m-0 mb-[18px] text-[13px] font-medium tracking-[0.16em] uppercase">
            {t(col.headingKey, locale)}
          </h3>
          <ul class="text-body m-0 grid list-none gap-[10px] p-0 text-[15px]">
            {col.itemKeys.map((key) => (
              <li>{t(key, locale)}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
