---
import Logo from './Logo.astro';
import Cat from './Cat.astro';
import { t, resolveLocale, contact } from '../lib/i18n';

const locale = resolveLocale(Astro.currentLocale);
---

<section class="bg-ink text-canvas relative">
  <div class="mx-auto max-w-[1080px] px-10 pt-[110px] pb-[90px]">
    <Logo width={26} height={35} class="text-canvas mb-10 block" data-reveal />

    <h2
      data-reveal
      class="m-0 mb-12 max-w-[760px] font-serif text-[clamp(34px,5vw,56px)] leading-[1.15] font-light tracking-[-0.01em] italic"
    >
      {t('ui_footer_headline', locale)}
    </h2>

    <div data-reveal class="flex flex-wrap items-center gap-9 text-[16px]">
      <a href={`mailto:${contact.email}`} class="footer-link">{contact.email}</a
      >
      <span class="font-serif text-[rgba(246,245,242,0.6)] italic">
        {t('ui_footer_gmail_aside', locale)}{' '}
        <a
          href={`mailto:${contact.gmail}`}
          class="footer-link font-sans text-[16px] not-italic"
          >{contact.gmail}</a
        >
      </span>
      <a
        href={contact.linkedin}
        target="_blank"
        rel="noopener"
        class="footer-link">LinkedIn</a
      >
      <a
        href={contact.github}
        target="_blank"
        rel="noopener"
        class="footer-link">GitHub</a
      >
      <button
        type="button"
        data-print
        data-no-print
        class="text-canvas hover:bg-canvas hover:text-ink cursor-pointer rounded-xs border border-[rgba(246,245,242,0.35)] bg-transparent px-5 py-[10px] font-sans text-[13px] tracking-[0.14em] uppercase transition-all duration-200"
      >
        {t('ui_download_pdf', locale)}
      </button>
    </div>

    <p
      class="mt-[90px] text-[13px] tracking-[0.1em] text-[rgba(246,245,242,0.45)]"
    >
      {t('ui_footer_legal', locale)}
    </p>
  </div>

  {/* A quiet hello from the old rengifo.es — hover it */}
  <div
    class="pointer-events-auto flex justify-center pb-10 sm:absolute sm:right-6 sm:bottom-3 sm:block sm:pb-0"
    data-no-print
  >
    <Cat />
  </div>
</section>

<style>
  .footer-link {
    color: #f6f5f2;
    text-decoration-color: rgba(246, 245, 242, 0.4);
  }
  .footer-link:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }
</style>
