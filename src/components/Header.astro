---
import Logo from './Logo.astro';
import { t, resolveLocale, alternateHref, homeHref } from '../lib/i18n';

const locale = resolveLocale(Astro.currentLocale);
---

<header
  data-no-print
  class="border-hairline-soft sticky top-0 z-50 flex items-center justify-between border-b bg-[rgba(246,245,242,0.88)] px-6 py-5 backdrop-blur-md sm:px-10"
>
  <a
    href={homeHref(locale)}
    aria-label="Beltrán Rengifo"
    class="text-ink inline-flex no-underline"
  >
    <Logo width={18} height={24} />
  </a>
  <nav class="flex items-center gap-7">
    <a
      href={alternateHref(locale)}
      class="text-muted hover:text-ink font-sans text-[13px] tracking-[0.14em] uppercase no-underline transition-colors"
    >
      {t('ui_lang_switch', locale)}
    </a>
    <button
      type="button"
      data-print
      class="text-ink hover:border-ink hover:bg-ink hover:text-canvas cursor-pointer rounded-xs border border-[rgba(22,24,26,0.25)] bg-transparent px-[18px] py-[9px] font-sans text-[13px] tracking-[0.14em] uppercase transition-all duration-200"
    >
      PDF
    </button>
  </nav>
</header>
