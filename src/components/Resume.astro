---
import Header from './Header.astro';
import Hero from './Hero.astro';
import Experience from './Experience.astro';
import SideProjects from './SideProjects.astro';
import Capabilities from './Capabilities.astro';
import Education from './Education.astro';
import ContactFooter from './ContactFooter.astro';
---

<div>
  {/* Cursor-following glow (behind everything, fine pointers only) */}
  <div
    data-cursor-glow
    data-no-print
    aria-hidden="true"
    style="position: fixed; z-index: -1; top: 0; left: 0; width: 460px; height: 460px; border-radius: 50%; background: radial-gradient(circle, color-mix(in srgb, var(--accent) 8%, transparent) 0%, transparent 70%); pointer-events: none; opacity: 0; transition: opacity 0.6s ease;"
  >
  </div>

  <Header />
  <main>
    <Hero />
    <Experience />
    <SideProjects />
    <Capabilities />
    <Education />
  </main>
  <ContactFooter />
</div>
