---
import Header from './Header.astro';
import Hero from './Hero.astro';
import Experience from './Experience.astro';
import SideProjects from './SideProjects.astro';
import Capabilities from './Capabilities.astro';
import Education from './Education.astro';
import ContactFooter from './ContactFooter.astro';
import { t, resolveLocale } from '../lib/i18n';

const locale = resolveLocale(Astro.currentLocale);
---

<div class="relative">
  <a href="#main" class="skip-link no-underline">{t('ui_skip', locale)}</a>

  {/* Film-grain overlay for warmth/tactility */}
  <div class="grain" data-no-print aria-hidden="true"></div>

  {/* Scroll progress bar (recolours with the accent) */}
  <div
    class="scroll-progress"
    data-scroll-progress
    data-no-print
    aria-hidden="true"
  >
  </div>

  {/* Cursor-following glow (behind everything, fine pointers only) */}
  <div
    data-cursor-glow
    data-no-print
    aria-hidden="true"
    style="position: fixed; z-index: -1; top: 0; left: 0; width: 460px; height: 460px; border-radius: 50%; background: radial-gradient(circle, color-mix(in srgb, var(--accent) 16%, transparent) 0%, transparent 70%); pointer-events: none; opacity: 0; transition: opacity 0.6s ease;"
  >
  </div>

  {/* Ambient drifting shapes (parallax, behind everything) */}
  <div class="ambient" data-no-print aria-hidden="true">
    <div
      class="orb-wrap"
      data-parallax="115"
      data-parallax-scroll="0.32"
      style="top:14%;left:-14%;width:54vw;max-width:680px;aspect-ratio:1;"
    >
      <div
        class="orb"
        style="background: radial-gradient(circle, color-mix(in srgb, var(--accent) 11%, transparent) 0%, transparent 68%); animation: drift 30s ease-in-out infinite alternate;"
      >
      </div>
    </div>
    <div
      class="orb-wrap"
      data-parallax="85"
      data-parallax-scroll="0.24"
      style="top:42%;left:64%;width:42vw;max-width:540px;aspect-ratio:1;"
    >
      <div
        class="orb"
        style="background: radial-gradient(circle, color-mix(in srgb, var(--accent) 9%, transparent) 0%, transparent 70%); animation: drift 36s ease-in-out infinite alternate-reverse;"
      >
      </div>
    </div>
    <div
      class="orb-wrap"
      data-parallax="135"
      data-parallax-scroll="0.38"
      style="top:72%;left:24%;width:46vw;max-width:600px;aspect-ratio:1;"
    >
      <div
        class="orb"
        style="background: radial-gradient(circle, color-mix(in srgb, var(--accent) 10%, transparent) 0%, transparent 68%); animation: drift 33s ease-in-out infinite alternate;"
      >
      </div>
    </div>
  </div>

  <Header />
  <main id="main">
    <Hero />
    <Experience />
    <SideProjects />
    <Capabilities />
    <Education />
  </main>
  <ContactFooter />
</div>
