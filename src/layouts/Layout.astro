---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'en' | 'es';
}

const {
  title = 'Beltrán Rengifo — Senior Software Engineer',
  description = 'Beltrán Rengifo — senior full-stack engineer, frontend-deep, design systems. Madrid-based, available for new roles.',
  lang = 'en',
} = Astro.props;

const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F6F5F2" />
    {canonical && <link rel="canonical" href={canonical.href} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:ital,wght@0,400;0,500;0,600;1,400&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;1,6..72,300;1,6..72,400&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical.href} />}

    <title>{title}</title>

    <script>
      import '../scripts/resume.ts';
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
